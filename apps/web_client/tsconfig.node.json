{
    "compilerOptions": {
        "composite": true,
        "types": ["node"],
        "lib": ["ESNext"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "skipLibCheck": true,
        "noUnusedLocals": true,
        "noEmit": true,
        "esModuleInterop": true
    },
    "include": [
        "scripts/",
        "types/",
        "eslint.config.ts",
        "l10n.config.ts",
        "lingui.config.ts",
        "postcss.config.ts",
        "prettier.config.ts",
        "tailwind.config.ts",
        "vite.config.ts"
    ]
}
