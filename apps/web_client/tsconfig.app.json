{
    "compilerOptions": {
        "composite": true,
        "target": "ESNext",
        "lib": ["DOM", "DOM.Iterable", "ESNext"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "skipLibCheck": true,
        "noUnusedLocals": true,
        "noEmit": true
    },
    "include": ["src/"]
}
